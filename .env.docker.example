# .env.docker.example v1.2.0 — variáveis para docker compose / Cloud Run
# VERSION: v1.2.0 | DATE: 2026-07-20
# Copie para .env.docker na raiz: cp .env.docker.example .env.docker

# MongoDB (local compose usa serviço mongo; GCP use Atlas)
MONGODB_URI=mongodb://mongo:27017/velodesk
MONGODB_DB_NAME=b2c_chamados
MONGODB_CADASTROS_DB_NAME=b2c_cadastros

JWT_SECRET=troque-em-producao
ENABLE_WHATSAPP=false

# LanguageTool (serviço languagetool no compose)
LANGUAGETOOL_ENABLED=true
LANGUAGETOOL_URL=http://languagetool:8010
LANGUAGETOOL_LANGUAGE=pt-BR

# Roleta de atribuição — ativa por padrão no deploy (opt-out: false)
ASSIGNMENT_ROUTER_ENABLED=true
ASSIGNMENT_ROUTER_STRATEGY=least_loaded
ASSIGNMENT_ROUTER_TERMINAL_STATUSES=resolvido,cancelado,fechado

# Cloud Run — serviço web (nginx proxy)
# BACKEND_URL=https://velodesk-api-xxxxx.run.app
