# .env.docker.example v1.0.0 — variáveis para docker compose / Cloud Run
# VERSION: v1.0.0 | DATE: 2026-06-24
# Copie para .env.docker na raiz: cp .env.docker.example .env.docker

# MongoDB (local compose usa serviço mongo; GCP use Atlas)
MONGODB_URI=mongodb://mongo:27017/velodesk
MONGODB_DB_NAME=b2c_chamados
MONGODB_CADASTROS_DB_NAME=b2c_cadastros

JWT_SECRET=troque-em-producao
ENABLE_WHATSAPP=false

# Cloud Run — serviço web (nginx proxy)
# BACKEND_URL=https://velodesk-api-xxxxx.run.app
