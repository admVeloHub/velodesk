# Contrato de variáveis — credenciais locais ficam em FONTE DA VERDADE/.env-velodesk
# VERSION: v1.3.0 | DATE: 2026-06-30
# Não copie este arquivo para .env no diretório do projeto; use o bootstrap em dev local.

VELODESK=8000
VELODESK_BACKEND=8001

# Auth Desk — fase testes: google | velohub (gate futuro)
VITE_DESK_AUTH_MODE=google

# Google OAuth — frontend (VITE_*) e backend (GOOGLE_CLIENT_ID)
# Se só GOOGLE_CLIENT_ID existir, o vite.config copia para VITE_GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# API VeloHub (VeloNews, colaboradores, etc.)
# Produção/build: URL do Cloud Run (sem /api no final)
# Dev local: o Vite faz proxy em /velohub-api (evita CORS na porta 8000)
# Ex.: https://velohub-278491073220.us-east1.run.app
VITE_VELOHUB_API_URL=
