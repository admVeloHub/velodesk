# Contrato de variáveis — credenciais compartilhadas em FONTE DA VERDADE/.env-velodesk
# VERSION: v1.1.0 | DATE: 2026-06-26
# backend/.env está no .gitignore — overrides locais (JWT, Mongo, etc.)
# GOOGLE_CLIENT_ID / VITE_GOOGLE_CLIENT_ID: definir em FONTE DA VERDADE/.env-velodesk

PORT=8001
NODE_ENV=development
VELODESK=8000
VELODESK_BACKEND=8001

MONGODB_URI=
MONGODB_DB_NAME=b2c_chamados
MONGODB_CADASTROS_DB_NAME=b2c_cadastros
MONGODB_DESK_CONFIG_DB_NAME=desk_config
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Google OAuth (login Desk fase testes)
GOOGLE_CLIENT_ID=

# WhatsApp (preencher no .env-velodesk quando habilitado)

# Gmail Workspace — desk_config.email_transport (seed: npm run seed:email-transport)
EMAIL_ENABLED=false
DESK_EMAIL_TRANSPORT_COLLECTION=email_transport
DESK_EMAIL_TRANSPORT_DOCUMENT_ID=desk_email_transport

# Gmail inbound via Pub/Sub (produção)
GMAIL_INBOUND_ENABLED=false
GCP_PROJECT_ID=velohub-471220
GMAIL_PUBSUB_TOPIC=gmail-desk-inbound
GMAIL_PUBSUB_VERIFY_TOKEN=
GMAIL_WATCH_STATE_COLLECTION=gmail_watch_state
GMAIL_WATCH_STATE_DOCUMENT_ID=desk_gmail_watch

# Inbound e-mail webhook (dev / fallback Mailgun)
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_PROVIDER=generic
INBOUND_EMAIL_WEBHOOK_SECRET=
INBOUND_EMAIL_ALLOWED_RECIPIENTS=

# Outbound e-mail (Fase 1b)
EMAIL_FROM=
EMAIL_API_KEY=

# LanguageTool open source (self-hosted) — corretor gramatical do compose
# Local sem Docker: docker run --rm -p 8010:8010 erikvl87/languagetool
LANGUAGETOOL_ENABLED=true
LANGUAGETOOL_URL=http://localhost:8010
LANGUAGETOOL_LANGUAGE=pt-BR
LANGUAGETOOL_TIMEOUT_MS=8000

# Gemini — refinar rascunho (Assistente IA no compose)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — sugestão IA de resposta e tabulação na abertura do ticket (vector store POPs)
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=
# Alias aceito pelo backend: VECTOR_STORE_PATH (mesmo valor vs_...)
OPENAI_MODEL=gpt-4.1-mini

# Roleta de atribuição — chamados sem responsavel (e-mail inbound, app integrado)
ASSIGNMENT_ROUTER_ENABLED=false
ASSIGNMENT_ROUTER_STRATEGY=least_loaded
ASSIGNMENT_ROUTER_TERMINAL_STATUSES=resolvido,cancelado,fechado

# App integrado — notificação pós-insert em chamados_n1 (header x-inbound-secret)
INBOUND_APP_WEBHOOK_SECRET=

# Sequência do chamadoProtocolo — valor numérico base (100177678 → exibido como 0100177678)
# Abaixo de 1.000.000.000: prefixo 0 + 9 dígitos (… até 0999999999); depois 1000000000+
TICKET_SEQUENCE_FLOOR=100177678

