# Contrato de variáveis — credenciais locais ficam em FONTE DA VERDADE/.env-velodesk
# VERSION: v1.0.2 | DATE: 2026-06-15
# Não copie este arquivo para .env no diretório do projeto; use o bootstrap em dev local.

PORT=8001
NODE_ENV=development
VELODESK=8000
VELODESK_BACKEND=8001

MONGODB_URI=
MONGODB_DB_NAME=b2c_chamados
JWT_SECRET=
JWT_EXPIRES_IN=7d

ENABLE_WHATSAPP=false

# WhatsApp (preencher no .env-velodesk quando habilitado)
