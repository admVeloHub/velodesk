{
  "name": "velodesk-backend",
  "version": "1.0.0",
  "description": "Backend Velodesk — API MongoDB + WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node ../scripts/free-port.cjs 8001",
    "dev": "tsx watch src/index.ts",
    "prestart": "node ../scripts/free-port.cjs 8001",
    "start": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-dist-assets.cjs",
    "start:prod": "node dist/index.js",
    "migrate:cliente-refs": "tsx scripts/migrate-cliente-refs.ts",
    "clear:demo-chamados": "tsx scripts/clear-demo-chamados.ts",
    "test:mongo": "tsx scripts/test-mongo-connection.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^2.2.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
